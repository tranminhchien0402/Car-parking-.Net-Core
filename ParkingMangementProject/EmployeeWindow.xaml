<Window x:Class="ASM.EmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ASM"
        Title="Nhân viên - Quản lý vé"
        Width="1000" Height="650"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid Margin="10">

        <!-- CHIA 3 HÀNG: HEADER – CONTENT – FOOTER -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Nội dung -->
            <RowDefinition Height="Auto"/>
            <!-- Nút đăng xuất -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Orientation="Horizontal"
                    Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Nhân viên: "
                       FontWeight="SemiBold" FontSize="14"/>
            <TextBlock x:Name="txtEmployeeName"
                       FontWeight="Bold" FontSize="14" Margin="4,0"/>
        </StackPanel>

        <!-- TAB CONTROL -->
        <TabControl Grid.Row="1">

            <TabItem Header="Vé lượt (Check-in / Check-out)">
                <local:TicketManagementPage/>
            </TabItem>

            <TabItem Header="Vé tháng (Đăng ký / Gia hạn)">
                <local:MonthlyPassPage/>
            </TabItem>

        </TabControl>

        <!-- FOOTER: NÚT ĐĂNG XUẤT -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">

            <Button Content="Đăng xuất"
                    Padding="12,6"
                    Background="#E53935"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Click="BtnLogout_Click"/>
        </StackPanel>

    </Grid>
</Window>
