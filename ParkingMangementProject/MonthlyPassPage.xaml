<UserControl x:Class="ASM.MonthlyPassPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- SEARCH -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBox x:Name="txtSearch" Width="200" Margin="0,0,10,0"/>
            <Button Content="Tìm" Width="80" Click="btnSearch_Click"/>
            <Button Content="Tải lại" Width="80" Margin="10,0,0,0" Click="btnReload_Click"/>
        </StackPanel>

        <!-- FORM -->
        <GroupBox Header="Đăng ký / Gia hạn vé tháng" Grid.Row="1">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- BIỂN SỐ -->
                <TextBlock Text="Biển số:"/>
                <TextBox x:Name="txtPlate"
                         Grid.Column="1"
                         Margin="5"
                         MaxLength="9"
                         TextChanged="txtPlate_TextChanged"/>

                <!-- LOẠI XE -->
                <TextBlock Text="Loại xe:" Grid.Row="1"/>
                <ComboBox x:Name="cbVehicleType"
                          Grid.Column="1" Grid.Row="1"
                          Margin="5"
                          DisplayMemberPath="TypeName"
                          SelectedValuePath="VehicleTypeId"
                          SelectionChanged="cbVehicleType_SelectionChanged"/>

                <!-- CHỦ XE -->
                <TextBlock Text="Chủ xe:" Grid.Row="2"/>
                <TextBox x:Name="txtOwner"
                         Grid.Column="1" Grid.Row="2"
                         Margin="5"
                         TextChanged="txtOwner_TextChanged"/>

                <!-- SĐT -->
                <TextBlock Text="SĐT:" Grid.Row="3"/>
                <TextBox x:Name="txtPhone"
                         Grid.Column="1" Grid.Row="3"
                         Margin="5"
                         MaxLength="12"
                         TextChanged="txtPhone_TextChanged"/>

                <!-- NGÀY BẮT ĐẦU -->
                <TextBlock Text="Từ ngày:" Grid.Row="4"/>
                <DatePicker x:Name="dpStart"
                            Grid.Column="1" Grid.Row="4"
                            Margin="5"
                            SelectedDateChanged="DateChanged"/>

                <!-- NGÀY KẾT THÚC -->
                <TextBlock Text="Đến ngày:" Grid.Row="5"/>
                <DatePicker x:Name="dpEnd"
                            Grid.Column="1" Grid.Row="5"
                            Margin="5"
                            SelectedDateChanged="DateChanged"/>

                <!-- CỘT BÊN PHẢI -->
                <StackPanel Grid.Column="2" Grid.RowSpan="6" Margin="15,0,0,0">

                    <TextBlock Text="Giá vé:"/>
                    <TextBox x:Name="txtPrice"
                             Margin="0,5,0,15"
                             IsReadOnly="True"
                             Background="#EEE"/>

                    <Button Content="Đăng ký mới"
                            Height="30"
                            Margin="0,0,0,10"
                            Click="btnRegister_Click"/>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Gia hạn (tháng):" Margin="0,0,5,0"/>
                        <TextBox x:Name="txtMonths" Width="40" Text="1"/>
                    </StackPanel>

                    <Button Content="Gia hạn"
                            Margin="0,10,0,0"
                            Height="30"
                            Click="btnRenew_Click"/>

                    <Button Content="Hủy vé"
                            Height="30"
                            Margin="0,10,0,0"
                            Click="btnDeactivate_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- LIST -->
        <DataGrid x:Name="dgMonthlyPass"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  Margin="0,10,0,10"
                  IsReadOnly="True"
                  SelectionChanged="dgMonthlyPass_SelectionChanged">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Biển số" Binding="{Binding LicensePlate}" Width="*"/>
                <DataGridTextColumn Header="Chủ xe" Binding="{Binding OwnerName}" Width="*"/>
                <DataGridTextColumn Header="Loại xe" Binding="{Binding VehicleTypeName}" Width="*"/>
                <DataGridTextColumn Header="Bắt đầu" Binding="{Binding StartDate, StringFormat='dd/MM/yyyy'}"/>
                <DataGridTextColumn Header="Kết thúc" Binding="{Binding EndDate, StringFormat='dd/MM/yyyy'}"/>
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding StatusText}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="txtMessage"
                   Grid.Row="3"
                   Foreground="Red"/>
    </Grid>
</UserControl>
