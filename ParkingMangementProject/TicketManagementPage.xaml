<UserControl x:Class="ASM.TicketManagementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- FORM CHECK-IN -->
        <Border Grid.Column="0" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,20,0">
            <StackPanel>
                <TextBlock Text="CHECK-IN XE VÀO" FontSize="20" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20"/>

                <TextBlock Text="Biển số xe:" FontWeight="SemiBold"/>
                <TextBox x:Name="txtLicensePlate" Height="35" Margin="0,5,0,15" Padding="5" FontSize="14"/>

                <TextBlock Text="Loại xe:" FontWeight="SemiBold"/>
                <ComboBox x:Name="cboVehicleType" Height="35" Margin="0,5,0,20"
                          DisplayMemberPath="TypeName"
                          SelectedValuePath="VehicleTypeId"
                          FontSize="14"/>

                <Button Content="CHECK IN" Height="45" Background="#2196F3" Foreground="White"
                        FontWeight="Bold" FontSize="16" Click="btnCheckIn_Click" Cursor="Hand"/>

                <Separator Margin="0,30"/>

                <TextBlock Text="THÔNG TIN CHECK-OUT" FontSize="18" FontWeight="Bold" Foreground="#F44336"/>
                <TextBlock x:Name="txtCheckOutInfo" Text="Chọn một xe trong danh sách để thanh toán"
                           TextWrapping="Wrap" Margin="0,10" FontStyle="Italic" Foreground="Gray"/>

                <Button x:Name="btnCheckOut" Content="THANH TOÁN &amp; RA" Height="45" Background="#F44336"
                        Foreground="White" FontWeight="Bold" FontSize="16" IsEnabled="False"
                        Click="btnCheckOut_Click" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- DANH SÁCH XE -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="DANH SÁCH XE ĐANG TRONG BÃI"
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

            <DataGrid Grid.Row="1" x:Name="dgvTickets" AutoGenerateColumns="False"
                      IsReadOnly="True" SelectionMode="Single"
                      SelectionChanged="dgvTickets_SelectionChanged">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã Vé"   Binding="{Binding TicketCode}" Width="100"/>
                    <DataGridTextColumn Header="Biển Số" Binding="{Binding LicensePlate}" Width="100"/>
                    <DataGridTextColumn Header="Loại Xe" Binding="{Binding VehicleType.TypeName}" Width="120"/>
                    <DataGridTextColumn Header="Giờ Vào" Binding="{Binding CheckInTime, StringFormat='dd/MM/yyyy HH:mm'}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
