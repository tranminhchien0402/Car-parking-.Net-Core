<Window x:Class="ASM.AdminDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard"
        Width="1000" Height="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="8">

        <!-- 3 hàng: Header – Nội dung – Footer Logout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- HEADER -->
            <RowDefinition Height="*"/>
            <!-- MAIN CONTENT -->
            <RowDefinition Height="Auto"/>
            <!-- FOOTER (LOGOUT) -->
        </Grid.RowDefinitions>

        <!-- ==========================================================
             ===============   HEADER (Tên người dùng)   ===============
             ========================================================== -->
        <StackPanel Orientation="Horizontal"
                    Grid.Row="0"
                    Margin="0,0,0,10">
            <TextBlock Text="Xin chào: " FontWeight="SemiBold"/>
            <TextBlock x:Name="txtCurrentUser"
                       FontWeight="Bold"
                       Margin="4,0,0,0"/>
        </StackPanel>

        <!-- ==========================================================
             ===================   MAIN TABS   =========================
             ========================================================== -->
        <TabControl Grid.Row="1">

            <!-- ===========================
                 TAB 1 — Nhân viên & tài khoản
                 =========================== -->
            <TabItem Header="Nhân viên &amp; tài khoản">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- DANH SÁCH NHÂN VIÊN -->
                    <DataGrid x:Name="dgEmployees"
                              Grid.Column="0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="dgEmployees_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding EmployeeId}" Width="60"/>
                            <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Giới tính" Binding="{Binding Gender}" Width="80"/>
                            <DataGridTextColumn Header="SĐT" Binding="{Binding Phone}" Width="100"/>
                            <DataGridTextColumn Header="Ca làm" Binding="{Binding Shift.ShiftName}" Width="110"/>
                            <DataGridTextColumn Header="Username" Binding="{Binding User.Username}" Width="110"/>
                            <DataGridTextColumn Header="Role" Binding="{Binding User.Role}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- FORM CHỈNH SỬA -->
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Họ tên:"/>
                        <TextBox x:Name="txtEmpName" Margin="0,2,0,6"/>

                        <TextBlock Text="Giới tính:"/>
                        <ComboBox x:Name="cbGender" Margin="0,2,0,6">
                            <ComboBoxItem Content="Nam"/>
                            <ComboBoxItem Content="Nữ"/>
                        </ComboBox>

                        <TextBlock Text="Địa chỉ:"/>
                        <TextBox x:Name="txtEmpAddress" Margin="0,2,0,6"/>

                        <TextBlock Text="SĐT:"/>
                        <TextBox x:Name="txtEmpPhone" Margin="0,2,0,6"/>

                        <TextBlock Text="Ca làm:"/>
                        <ComboBox x:Name="cbShift"
                                  Margin="0,2,0,6"
                                  DisplayMemberPath="ShiftName"
                                  SelectedValuePath="ShiftId"/>

                        <TextBlock Text="Username:"/>
                        <TextBox x:Name="txtEmpUsername" Margin="0,2,0,6"/>

                        <TextBlock Text="Mật khẩu (khi thêm / reset):"/>
                        <PasswordBox x:Name="txtEmpPassword" Margin="0,2,0,6"/>

                        <TextBlock Text="Quyền (Role):"/>
                        <ComboBox x:Name="cbRole" Margin="0,2,0,6">
                            <ComboBoxItem Content="Admin"/>
                            <ComboBoxItem Content="Employee"/>
                        </ComboBox>

                        <CheckBox x:Name="chkActive"
                                  Content="Kích hoạt tài khoản"
                                  Margin="0,4,0,8"
                                  IsChecked="True"/>

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="Thêm mới" Width="80" Margin="0,0,4,0"
                                    Click="BtnAddEmp_Click"/>
                            <Button Content="Cập nhật" Width="80" Margin="0,0,4,0"
                                    Click="BtnUpdateEmp_Click"/>
                            <Button Content="Xóa" Width="70" Margin="0,0,4,0"
                                    Click="BtnDeleteEmp_Click"/>
                            <Button Content="Reset MK" Width="80"
                                    Click="BtnResetPass_Click"/>
                        </StackPanel>

                        <TextBlock x:Name="txtEmpMessage"
                                   Margin="0,8,0,0"
                                   Foreground="Red"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ===========================
                 TAB 2 — Trạng thái bãi xe
                 =========================== -->
            <TabItem Header="Trạng thái bãi xe">
                <StackPanel Margin="16">
                    <TextBlock Text="Thông tin bãi xe"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Tổng số chỗ: " FontWeight="SemiBold"/>
                        <TextBlock x:Name="txtTotalSlots"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Đang gửi: " FontWeight="SemiBold"/>
                        <TextBlock x:Name="txtOccupiedSlots"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Còn trống: " FontWeight="SemiBold"/>
                        <TextBlock x:Name="txtFreeSlots"/>
                    </StackPanel>

                    <Button Content="Làm mới"
                            Width="100"
                            Margin="0,12,0,0"
                            Click="BtnRefreshLot_Click"/>
                </StackPanel>
            </TabItem>

            <!-- ===========================
                 TAB 3 — Thống kê doanh thu
                 =========================== -->
            <TabItem Header="Thống kê doanh thu">
                <StackPanel Margin="16">

                    <!-- Doanh thu theo ngày -->
                    <TextBlock Text="Doanh thu theo ngày"
                               FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <DatePicker x:Name="dpRevenueDate" Width="160"/>
                        <Button Content="Xem"
                                Width="80"
                                Margin="8,0,0,0"
                                Click="BtnRevenueByDate_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="txtRevenueDate"
                               Margin="0,4,0,16"
                               TextWrapping="Wrap"/>

                    <!-- Doanh thu theo tháng -->
                    <TextBlock Text="Doanh thu theo tháng"
                               FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Năm:" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtYear"
                                 Width="60"
                                 Margin="4,0,12,0"/>

                        <TextBlock Text="Tháng:" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtMonth"
                                 Width="40"
                                 Margin="4,0,12,0"/>

                        <Button Content="Xem"
                                Width="80"
                                Click="BtnRevenueByMonth_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="txtRevenueMonth"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"/>

                </StackPanel>
            </TabItem>

        </TabControl>

        <!-- ==========================================================
             ===================   FOOTER ĐĂNG XUẤT   =================
             ========================================================== -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">

            <Button Content="Đăng xuất"
                    Padding="12,5"
                    Background="#E53935"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Click="BtnLogout_Click"/>
        </StackPanel>

    </Grid>
</Window>
